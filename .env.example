# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider (pick one)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, cheapest)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=              # Override model name
# SCORING_LLM_MODEL=      # Optional stage-specific override
# TAILOR_LLM_MODEL=       # Optional stage-specific override
# COVER_LLM_MODEL=        # Optional stage-specific override

# Auto-Apply (optional)
APPLYPILOT_APPLY_BACKEND=claude   # claude or command
# APPLYPILOT_AGENT_COMMAND=python scripts/local_apply_agent.py --provider ollama --model qwen3:4b
# APPLYPILOT_AGENT_BASE_URL=http://127.0.0.1:11434
# APPLYPILOT_AGENT_API_KEY=       # for OpenAI-compatible remote endpoints
# APPLYPILOT_AGENT_TIMEOUT=300
# APPLYPILOT_ACCOUNT_PASSWORD=    # optional fixed password for specific Workday tenants
# APPLYPILOT_ACCOUNT_PASSWORD_HOSTS=thomsonreuters.wd5.myworkdayjobs.com
# APPLYPILOT_ACCOUNT_PASSWORDS_FILE=~/.applypilot/account_passwords.json
# APPLYPILOT_IMAP_HOST=imap.gmail.com
# APPLYPILOT_IMAP_PORT=993
# APPLYPILOT_IMAP_USER=you@gmail.com
# APPLYPILOT_IMAP_PASSWORD=       # app password or mailbox token
# APPLYPILOT_IMAP_FOLDER=INBOX
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
